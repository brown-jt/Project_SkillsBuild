      m_Calls: []
  m_text: "The main starting zone is the forest zone. Feel free\nto explore and interact
    with the signposted courses to\ntravel to them and learn their included content.\n\nAll
    courses are independent of one another and all\nhave unique questlines for you
    to explore. \nAll content is taken from IBM Skills Build.\n\nSaving happens automatically
    and you can restart\nat any point, continuing from where you left off.\n\nTo
    move your character, use the WASD keys and\nSpace to jump. Further interaction
    can be seen on\nscreen, pressing the corresponding button to action.\n\nHave
    fun and thank you for play testing!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
