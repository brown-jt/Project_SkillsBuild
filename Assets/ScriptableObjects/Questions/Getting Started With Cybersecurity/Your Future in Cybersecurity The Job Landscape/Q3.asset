  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: Q3
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: "If you\u2019d like to pursue a career in cybersecurity, getting an industry-recognized
    certification can help accelerate your learning.\r\nWhich of the following items
    is an industry-recognized cybersecurity certification that you can consider in
    the future?\r\nSelect all that apply."
  answers:
  - Certified Virus Defense Specialist (CVDS)
  - CompTIA Data Guardian (CDG)
  - Certified Ethical Hacker (C|EH)
  - CompTIA Cybersecurity Analyst (CySA+)
  maxSelections: 4
  correctAnswerIndices: 0200000003000000
  correctMessage: Two industry-recognized cybersecurity certifications that you can
    consider in the future include CompTIA Cybersecurity Analyst (CySA+) and Certified
    Ethical Hacker (C|EH).
  incorrectMessage: Not quite. Consider which certifications are industry-recognized
    cybersecurity certifications from leading providers.
