  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_1_Final_Assessment_Q3
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: "Ekon needs a brief summary of the key points in a blog post he is writing.
    He prompts, \u201CSummarize this blog post.\u201D Although the output is brief,
    he wants it provided as a list of bullets.\r\nWhat is the best refinement technique
    Ekon can apply to the prompt to generate the output he wants?"
  questionId: 2
  answers:
  - Adding a constraint related to the tone of the response
  - Adding the role the AI should take and expertise that should be used
  - Adding the format the output should take
  - Adding background information to contextualize the request
  maxSelections: 1
  correctAnswerIndices: 02000000
  correctMessage: Refining prompts by specifying the output, such as format or structure,
    helps generative AI create appropriate responses.
  incorrectMessage: Not quite. Consider what refinement helps the AI tool structure
    the output.
