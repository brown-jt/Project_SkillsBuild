  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_1_Lesson_4_Q3
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: "Sam wants to explain AI to his 6-year old nephew. He enters the prompt,
    \u201CGive me a brief description of AI.\u201D Although the response is good,
    it won\u2019t be understood by his nephew. \r\nWhat is the best refinement Sam
    can make to the prompt to generate a response his nephew would easily understand?"
  answers:
  - Adding background information
  - Adding a constraint limiting the length of the response
  - Adding the role the AI should take and expertise that should be used
  - Adding the format the output should take
  maxSelections: 1
  correctAnswerIndices: 02000000
  correctMessage: Refining prompts by adding the role AI should take enables AI to
    generate responses that are appropriate for the audience.
  incorrectMessage: Not quite. Consider the prompt refinement that would make the
    response appropriate for the audience.
