  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_3_Lesson_3_Q2
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: "Which prompting technique best matches the given scenario?\nA team asks
    the LLM to \u201CAnalyze this customer feedback\u201D, but the results are irrelevant
    and do not identify customer complaints."
  answers:
  - Define the task clearly
  - Be specific
  - Include examples
  - Use simple and direct language
  maxSelections: 1
  correctAnswerIndices: 00000000
  correctMessage: Clearly defining the task avoids vague or irrelevant results, ensuring
    the LLM knows exactly what to deliver.
  incorrectMessage: Not quite. Consider how vague instructions can confuse the LLM
    and what technique eliminates that confusion.
