  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_2_Lesson_3_Q2
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'What ethical implication does the following scenario best explain?

    A
    business discloses that its chatbot interactions are powered by AI and not a
    human representative.'
  answers:
  - Transparency
  - Accountability
  - Managing bias
  - Respecting intellectual property and privacy
  - Preventing harmful and inaccurate content
  maxSelections: 1
  correctAnswerIndices: 00000000
  correctMessage: Transparency enables AI users to understand how AI-generated content
    is created and when AI is being used, which helps build trust and accountability.
  incorrectMessage: Not quite. Consider which area explains the importance of clearly
    communicating AI processes and involvement.
