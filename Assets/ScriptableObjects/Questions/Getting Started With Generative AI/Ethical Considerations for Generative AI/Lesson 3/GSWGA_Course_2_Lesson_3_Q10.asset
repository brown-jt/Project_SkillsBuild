  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_2_Lesson_3_Q10
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'What ethical implication does the following scenario best explain?

    A
    team monitors its generative AI to identify and correct any biased outputs and
    retrains the tool based on flagged issues.'
  answers:
  - Transparency
  - Accountability
  - Managing bias
  - Respecting intellectual property and privacy
  - Preventing harmful and inaccurate content
  maxSelections: 1
  correctAnswerIndices: 01000000
  correctMessage: Accountable organizations take responsibility for AI decisions
    by tracking outputs, monitoring biases, and making necessary corrections.
  incorrectMessage: Not quite. Think about which area explains how AI decision making
    is monitored and adjusted to maintain ethical integrity.
