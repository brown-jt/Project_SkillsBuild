  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_2_Final_Assessment_Q1
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'A social media platform uses AI to moderate content but does not disclose
    how its algorithm filters posts. Users begin to question whether the platform
    is suppressing certain viewpoints unfairly.

    What ethical concept should
    the company prioritize to address this concern?'
  answers:
  - Reducing inaccurate information
  - Providing transparency
  - Preventing harmful content
  - Managing bias
  maxSelections: 1
  correctAnswerIndices: 01000000
  correctMessage: Transparency helps users understand how AI decisions are made and
    helps build trust in AI-generated content.
  incorrectMessage: Not quite. Consider which concept involves openly sharing information
    about how AI operates and makes decisions.
