  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_2_Final_Assessment_Q5
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: "A company is developing an AI chatbot to assist customers with financial
    inquiries. To improve accuracy, the chatbot is trained using actual customer
    conversations. However, during a live session, a user notices that the chatbot
    references specific details from another customer\u2019s past inquiry, suggesting
    that the data was not properly anonymized or protected.\r\nWhat ethical risk
    arises from using real customer data as AI training inputs?"
  answers:
  - Lack of fairness
  - Lack of transparency
  - Dataset imbalance
  - Data privacy violation
  maxSelections: 1
  correctAnswerIndices: 03000000
  correctMessage: AI tools must protect sensitive data by anonymizing or securing
    data to protect privacy of training inputs.
  incorrectMessage: Not quite. Consider which risk involves protecting personal information
    from exposure.
