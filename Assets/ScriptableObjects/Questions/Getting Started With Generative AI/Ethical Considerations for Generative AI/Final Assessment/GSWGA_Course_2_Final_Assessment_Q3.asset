  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWGA_Course_2_Final_Assessment_Q3
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'An AI-powered hiring tool is designed to screen job applicants based
    on previous successful hires. However, the AI tool favors candidates similar
    to past hires because it was trained on past hiring patterns that lacked diversity.

    What
    ethical risk does this scenario highlight?'
  answers:
  - Privacy violation
  - Misuse of personal data
  - Lack of fairness
  - Limited data security
  maxSelections: 1
  correctAnswerIndices: 02000000
  correctMessage: 'AI tools must use diverse training data to prevent biased outcomes. '
  incorrectMessage: Not quite. Consider how the AI tool's training data influences
    its hiring recommendations.
