  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: Intro_LLM_Set_Q2
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: What makes transformers special in handling text?
  answers:
  - They work better with numbers than with words.
  - They can read and write text simultaneously.
  - They can pay attention to all parts of the sentence at once.
  - They focus only on the most recent word in a sentence.
  maxSelections: 1
  correctAnswerIndices: 02000000
  correctMessage: Transformers are designed to understand the context of each word
    in a sentence by considering it in relation to every other word.
  incorrectMessage: Transformers are designed to understand the context of each word
    in a sentence by considering it in relation to every other word.
