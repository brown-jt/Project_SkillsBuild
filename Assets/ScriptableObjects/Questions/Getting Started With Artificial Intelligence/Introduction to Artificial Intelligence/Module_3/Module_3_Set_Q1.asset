  m_Name: Module_3_Set_Q1
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: "Shelby writes a survey that includes the following question: \u201CDo
    you like chocolate (circle Yes or No), and why?\u201D\nWhich of the following
    describes the data Shelby will collect?"
  answers:
  - Both structured data and unstructured data
  - Unstructured data
  - Structured data
  - Neither structured data nor unstructured data
  maxSelections: 1
  correctAnswerIndices: 00000000
  correctMessage: "In the first part of the question, \u201CDo you like chocolate
    (circle Yes or No)...\u201D, Shelby collects structured data. In the second part
    of the question, \u201Cand why?\u201D, Shelby collects unstructured data."
  incorrectMessage: "In the first part of the question, \u201CDo you like chocolate
    (circle Yes or No)...\u201D, Shelby collects structured data. In the second part
    of the question, \u201Cand why?\u201D, Shelby collects unstructured data."
