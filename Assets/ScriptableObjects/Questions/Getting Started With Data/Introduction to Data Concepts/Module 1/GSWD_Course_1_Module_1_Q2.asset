  m_Name: GSWD_Course_1_Module_1_Q2
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'While reviewing a spreadsheet with customer information, you see that
    one of the columns contains data for the marital status of the customers.

    What
    type of data is this?'
  answers:
  - Ordinal
  - Nominal
  - Discrete
  - Continuous
  maxSelections: 1
  correctAnswerIndices: 01000000
  correctMessage: "This is nominal data, since it\u2019s not numerical, but rather
    labels a variable. In this case, the variable is a customer\u2019s marital status.  "
  incorrectMessage: "This is nominal data, since it\u2019s not numerical, but rather
    labels a variable. In this case, the variable is a customer\u2019s marital status.  "
