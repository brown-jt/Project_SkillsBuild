  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWD_Course_1_Module_5_Q3
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'What is the purpose of a data visualization?

    Select one of the
    two that apply.'
  questionId: 2
  answers:
  - 'Organize data in a usable format, such as a spreadsheet, for people to easily
    access.  '
  - 'Explore and interpret data during analysis to identify patterns or trends.  '
  - 'Communicate results and help people understand the insights to make decisions.  '
  maxSelections: 2
  correctAnswerIndices: 0100000002000000
  correctMessage: 'Data analysts use visualizations like charts, graphs, and maps
    for two reasons: to explore and interpret data during analysis to identify patterns
    or trends; and to communicate results and help people understand the insights
    to make decisions.'
  incorrectMessage: 'Data analysts use visualizations like charts, graphs, and maps
    for two reasons: to explore and interpret data during analysis to identify patterns
    or trends; and to communicate results and help people understand the insights
    to make decisions.'
