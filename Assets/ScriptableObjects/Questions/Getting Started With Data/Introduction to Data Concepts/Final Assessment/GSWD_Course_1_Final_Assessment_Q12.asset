  m_Name: GSWD_Course_1_Final_Assessment_Q12
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'You are reviewing a spreadsheet containing information about the people
    who will be attending a conference. You notice that one of the columns contains
    the city in which each attendee lives.

    What type of data is this?'
  answers:
  - Ordinal
  - Discrete
  - Nominal
  - Continuous
  maxSelections: 1
  correctAnswerIndices: 02000000
  correctMessage: "This type of data can be grouped into a category, such as location,
    and isn\u2019t numeric."
  incorrectMessage: "Not quite. Consider that although this data isn\u2019t numeric,
    it can be grouped in a category and labeled, for example, location."
