  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWD_Course_1_Final_Assessment_Q4
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'A large retail company has collected a huge amount of data, such as
    customer purchases, sales, financial reports, and payroll, in its computer systems.
    This data is located in databases.

    What is the purpose of a database?'
  answers:
  - To collect all types of data in tables and make it meaningful
  - To store structured data to make it easier to analyze
  - To duplicate data to ensure a backup can be saved
  - To organize unstructured data into a standard format
  maxSelections: 1
  correctAnswerIndices: 01000000
  correctMessage: Databases organize data in columns and rows making it easy for
    data analysts to access it and run queries.
  incorrectMessage: "Not quite. Consider the type of data stored in databases and
    why it\u2019s stored in databases."
