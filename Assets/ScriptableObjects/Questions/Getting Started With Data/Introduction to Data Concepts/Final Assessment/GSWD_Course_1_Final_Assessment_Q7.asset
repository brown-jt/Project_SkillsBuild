  m_Script: {fileID: 11500000, guid: 3507d679efa283143b52308c9a6a3292, type: 3}
  m_Name: GSWD_Course_1_Final_Assessment_Q7
  m_EditorClassIdentifier: Assembly-CSharp::QuestionData
  question: 'During analysis, data analysts create visualizations like charts, graphs,
    and maps to explore and interpret data to identify patterns or trends.

    Which
    of the following is another reason data analysts create data visualizations?'
  questionId: 6
  answers:
  - Communicate results and help people understand the insights to make decisions
  - Publish data in a presentation template
  - Increase the complexity and significance of the presentation
  - Organize data in a usable format, such as a spreadsheet, for people to easily
    access
  maxSelections: 1
  correctAnswerIndices: 00000000
  correctMessage: Graphical representations bring clarity and simplicity to complicated
    issues.
  incorrectMessage: Not quite. Consider the purpose of data visualizations.
